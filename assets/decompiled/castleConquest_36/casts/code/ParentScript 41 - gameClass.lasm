on getCannon me, castlePieceList
  [  0] pusharglist 0 ........................... <>
  [  2] extcall 257 ............................. <VOID>
  [  5] setlocal 0 .............................. tCannon = VOID
  [  7] getparam 1 .............................. <castlePieceList>
  [  9] getobjprop 264 .......................... <castlePieceList.count>
  [ 12] setlocal 1 .............................. tCount = castlePieceList.count
  [ 14] pushint8 1 .............................. <1>
  [ 16] setlocal 2
  [ 18] getlocal 2
  [ 20] getlocal 1 .............................. <tCount>
  [ 22] lteq
  [ 23] jmpifz [ 64] ............................ repeat with i = 1 to tCount
  [ 26] getparam 1 .............................. <castlePieceList>
  [ 28] getlocal 2 .............................. <i>
  [ 30] pusharglist 2 ........................... <castlePieceList, i>
  [ 32] objcall 265 ............................. <castlePieceList[i]>
  [ 35] setlocal 3 .............................. tCastlePiece = castlePieceList[i]
  [ 37] getlocal 3 .............................. <tCastlePiece>
  [ 39] getobjprop 258 .......................... <tCastlePiece.name>
  [ 42] pushcons 49 ............................. <"cannon">
  [ 44] containsstr ............................. <tCastlePiece.name contains "cannon">
  [ 45] jmpifz [ 55] ............................ if tCastlePiece.name contains "cannon" then
  [ 48] getlocal 3 .............................. <tCastlePiece>
  [ 50] setlocal 0 .............................. tCannon = tCastlePiece
  [ 52] jmp [ 64] ............................... exit repeat
  [ 55] pushint8 1
  [ 57] getlocal 2
  [ 59] add
  [ 60] setlocal 2
  [ 62] endrepeat [ 18]
  [ 64] getlocal 0 .............................. <tCannon>
  [ 66] pusharglistnoret 1 ...................... <tCannon>
  [ 68] extcall 58 .............................. return tCannon
  [ 70] ret
